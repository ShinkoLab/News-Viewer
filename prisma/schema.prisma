generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model article_summaries {
  id             Int       @id @default(autoincrement())
  batch_id       Int
  source_type    String
  source_id      String
  original_title String
  original_url   String?
  summary_title  String
  summary_text   String
  keywords       String
  category       String
  group_id       Int?
  group_topic    String?
  published_at   DateTime?
  created_at     DateTime  @default(now())
  embedding      String?
  batches        batches   @relation(fields: [batch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_summaries_created")
  @@index([category], map: "idx_summaries_category")
  @@index([batch_id], map: "idx_summaries_batch")
}

model batches {
  id                Int                 @id @default(autoincrement())
  executed_at       DateTime            @default(now())
  total_articles    Int
  digest_text       String?
  article_summaries article_summaries[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model processed_emails {
  uidl         String?  @id
  processed_at DateTime @default(now())

  @@ignore
}
